# --- Arduino IDE Build Artifacts ---
# Exclude the temporary directory where Arduino IDE compiles your ESP32 binary files
/build/
build/
*.tmp
*.bak
*.elf
*.bin
*.hex

# --- Sensitive Data & Credentials ---
# Always ignore files containing your Wi-Fi credentials or private API keys
secrets.h
config_private.h
.env

# --- Arduino IDE 2.x & VS Code Metadata ---
# Exclude local editor settings, workspace configurations, and search caches
.vscode/
.arduinoIDE/
.local/

# --- Operating System Files ---
# Ignore system-specific metadata files
.DS_Store
Thumbs.db
